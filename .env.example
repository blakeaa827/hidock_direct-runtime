# HiDock Direct — configuration template.
# Copy to .env (cp .env.example .env) and fill in your AssemblyAI key.
# .env is gitignored; this template is committed. Never put a real key here.

# --- Required ---------------------------------------------------------------
# Your AssemblyAI API key (https://www.assemblyai.com/ → dashboard).
# Consumed by the vendored diarize_audio for transcription + diarization.
ASSEMBLYAI_API_KEY=

# --- Archive ----------------------------------------------------------------
# Where offloaded audio + transcripts (.mp3/.md/.aai.json) are written.
# A plain local folder works; no Google Drive required.
HIDOCK_ARCHIVE_DIR=~/HiDock/archive

# --- Google Drive upload (optional, off by default) -------------------------
# Leave false to transcribe to the local archive only (no GCP credentials).
# Setting true ALSO requires the Drive extra:  pip install ".[drive]"
DRIVE_ENABLED=false

# --- Behavior (optional; defaults shown) ------------------------------------
# Transcribe each recording immediately after offload.
TRANSCRIBE_ON_OFFLOAD=true
# Delete the file from the HiDock device after a successful offload.
DELETE_FROM_DEVICE_AFTER_OFFLOAD=false
# Seconds between device polls.
POLL_INTERVAL_SECONDS=10
# Log verbosity: debug | info | warning | error
LOG_LEVEL=info

# --- Transcription tuning (optional; uncomment to override) -----------------
# AssemblyAI model: best | nano
#SPEECH_MODEL=best
# Force a language instead of auto-detect (e.g. en). Blank = auto.
#LANGUAGE_CODE=
# Comma-separated terms to boost recognition (names, jargon).
#WORD_BOOST=
